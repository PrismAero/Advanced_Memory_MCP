{
  "name": "@prism.enterprises/adaptive-reasoning-server",
  "version": "1.0.0",
  "description": "Adaptive Reasoning Server: SQLite-based memory and knowledge management system for AI assistants",
  "license": "MIT",
  "author": "Kai Wyborny - Based on original by Anthropic, PBC",
  "homepage": "https://modelcontextprotocol.io",
  "bugs": "https://github.com/PrismAero/adaptive-reasoning-server/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/PrismAero/adaptive-reasoning-server.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "memory",
    "knowledge-graph",
    "ai",
    "assistant",
    "reasoning",
    "adaptive",
    "persistent-memory"
  ],
  "type": "module",
  "bin": {
    "adaptive-reasoning-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "security-audit": "npm audit && echo '✅ Local-only operation verified'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.2",
    "@tensorflow/tfjs": "^4.15.0",
    "@tensorflow/tfjs-node": "^4.15.0",
    "@tensorflow-models/universal-sentence-encoder": "^1.3.3",
    "chokidar": "^3.5.3",
    "sqlite3": "^5.1.7",
    "tiktoken": "^1.0.22"
  },
  "devDependencies": {
    "@types/node": "^24.5.1",
    "@types/sqlite3": "^3.1.11",
    "chokidar": "^3.5.3",
    "shx": "^0.4.0",
    "typescript": "^5.9.2"
  }
}
